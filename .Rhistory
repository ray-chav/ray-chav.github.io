# read in data
# daily closing prices on microsoft and sp 500 for a decade
dat <- read.csv("capm.csv", header = TRUE)
attach(dat)
n = dim(dat)[1]
EX_R_sp500 = Close.sp500[2:n]/Close.sp500[1:(n-1)] - 1 - Close.tbill[2:n]/(100*253)
EX_R_msft = Close.msft[2:n]/Close.msft[1:(n-1)] - 1 - Close.tbill[2:n] / (100*253)
# EX_R_msft - vector cotnaining the time series of excess returns for Microsoft
# EX_R_sp500 - vector containing the time series of excess returns for sp500
# time series - the same variable measured repeatedly over time
# I. plot ex_r_msft
hist(EX_R_msft,
col = 'lavender',
main = "Excess Returns for Microsoft")
# II. plot ex_r_sp500
hist(EX_R_sp500,
col = 'skyblue2',
main = "Excess Returns for SP500")
# plot a scatter plot of msft vs sp500
plot(EX_R_msft, EX_R_sp500,
xlab="Microsoft",
ylab="SP500",
main="Microsoft Returns vs SP500 Returns",
pch=20,
col="skyblue3")
# window size
w = 201
half_w = 100
T = length(EX_R_msft)
# create empty vectors
alpha_hat = c()
beta_hat = c()
# rolling regression
for (t in (1 + half_w):(T - half_w)) {
# define window
Y_window = EX_R_msft[(t - half_w):(t + half_w)]
X_window = EX_R_sp500[(t - half_w):(t + half_w)]
# run regression
fit = lm(Y_window ‾ X_window)
# store coefficients
alpha_hat = c(alpha_hat, coef(fit)[1])
beta_hat  = c(beta_hat,  coef(fit)[2])
}
plot(alpha_hat, type="l", col="purple",
main="Rolling Alpha (201-day window)",
ylab="Alpha", xlab="Time")
abline(h=0, col="red", lty=2)
plot(beta_hat, type="l", col="blue",
main="Rolling Beta (201-day window)",
ylab="Beta", xlab="Time")
abline(h=1, col="red", lty=2)
plot(alpha_hat, type="l", col="purple",
main="a (201-day window)",
ylab="Alpha", xlab="Time")
abline(h=0, col="red", lty=2)
plot(beta_hat, type="l", col="blue",
main="B (201-day window)",
ylab="Beta", xlab="Time")
abline(h=1, col="red", lty=2)
plot(alpha_hat, type="l", col="purple4",
main="a over 201-day window",
ylab="Alpha", xlab="Time")
abline(h=0, col="red", lty=2)
plot(beta_hat, type="l", col="blue4",
main="B over 201-day window",
ylab="Beta", xlab="Time")
abline(h=1, col="red", lty=2)
# time series - the same variable measured repeatedly over time
# I. plot ex_r_msft
plot(EX_R_msft,
col = 'lavender',
main = "Excess Returns for Microsoft")
# II. plot ex_r_sp500
plot(EX_R_sp500,
col = 'skyblue2',
main = "Excess Returns for SP500")
# time series - the same variable measured repeatedly over time
